# Service Configuration
SERVICE_NAME=ocr-service
SERVICE_PORT=8001
SERVICE_HOST=0.0.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# API Keys
OPENAI_API_KEY=your_openai_api_key_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/contract_ai

# OCR Configuration
OCR_ENGINE=paddle  # paddle, tesseract, or hybrid
OCR_LANGUAGE=en
OCR_CONFIDENCE_THRESHOLD=0.7
MAX_IMAGE_SIZE_MB=50
SUPPORTED_FILE_TYPES=pdf,png,jpg,jpeg,tiff,bmp,docx,doc,txt,rtf

# Tesseract Configuration
TESSERACT_CMD=/usr/bin/tesseract  # Path to tesseract binary
TESSERACT_LANG=eng

# PaddleOCR Configuration
PADDLE_USE_GPU=false
PADDLE_ENABLE_MKLDNN=true
PADDLE_CPU_THREADS=4

# Document Processing
ENABLE_LAYOUT_ANALYSIS=true
ENABLE_TABLE_EXTRACTION=true
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Performance
MAX_WORKERS=4
BATCH_SIZE=10
TIMEOUT_SECONDS=300

# Storage
TEMP_UPLOAD_DIR=/tmp/ocr-uploads
OUTPUT_DIR=/tmp/ocr-output
CLEANUP_AFTER_PROCESSING=true

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# API Service URLs
API_SERVICE_URL=http://localhost:3001
NOTIFICATION_SERVICE_URL=http://localhost:8002
