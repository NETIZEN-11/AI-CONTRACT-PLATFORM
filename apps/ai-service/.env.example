# Service Configuration
SERVICE_NAME=ai-service
SERVICE_PORT=8000
SERVICE_HOST=0.0.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# AI Model Configuration
PRIMARY_LLM_PROVIDER=openai        # openai, anthropic, google
PRIMARY_MODEL=gpt-4-turbo-preview
FALLBACK_LLM_PROVIDER=anthropic
FALLBACK_MODEL=claude-3-sonnet-20240229
EMBEDDING_MODEL=text-embedding-3-small

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Temperature & Token Settings
DEFAULT_TEMPERATURE=0.1
MAX_TOKENS=4096
CONTEXT_WINDOW=128000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/contract_ai

# Qdrant Vector Store
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=contract_embeddings
VECTOR_DIMENSION=1536

# Analysis Configuration
ENABLE_CLAUSE_EXTRACTION=true
ENABLE_RISK_DETECTION=true
ENABLE_COMPLIANCE_CHECK=true
ENABLE_ENTITY_EXTRACTION=true
ENABLE_SUMMARIZATION=true

# Risk Detection
RISK_CONFIDENCE_THRESHOLD=0.7
CRITICAL_RISK_KEYWORDS=unlimited liability,indemnification,warranty,termination
HIGH_RISK_KEYWORDS=payment,confidentiality,intellectual property

# Compliance Frameworks
ENABLE_GDPR_CHECK=true
ENABLE_HIPAA_CHECK=true
ENABLE_SOC2_CHECK=true
ENABLE_ISO27001_CHECK=true

# Performance
MAX_WORKERS=4
BATCH_SIZE=5
TIMEOUT_SECONDS=300
ENABLE_CACHING=true
CACHE_TTL_SECONDS=3600

# Rate Limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_PER_MINUTE=60

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9091
SENTRY_DSN=

# External Services
API_SERVICE_URL=http://localhost:3001
OCR_SERVICE_URL=http://localhost:8001
NOTIFICATION_SERVICE_URL=http://localhost:8002

# Feature Flags
ENABLE_MULTI_MODEL_COMPARISON=false
ENABLE_EXPERIMENTAL_FEATURES=false
ENABLE_CHAIN_OF_THOUGHT=true
