{
  "name": "contract-ai-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-grade AI Contract Review Platform",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint --no-cache",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "db:migrate": "turbo run db:migrate --filter=@contract-ai/api",
    "db:seed": "turbo run db:seed --filter=@contract-ai/api",
    "db:studio": "turbo run db:studio --filter=@contract-ai/api",
    "docker:build": "docker-compose -f infrastructure/docker/docker-compose.yml build",
    "docker:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "turbo": "^2.0.3",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.25"
    }
  }
}
