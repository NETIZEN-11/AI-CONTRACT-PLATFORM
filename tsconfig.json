{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@contract-ai/*": ["packages/*/src"],
      "@contract-ai/api": ["packages/api/src"],
      "@contract-ai/ui": ["packages/ui/src"],
      "@contract-ai/database": ["packages/database/src"],
      "@contract-ai/auth": ["packages/auth/src"],
      "@contract-ai/shared": ["packages/shared/src"],
      "@contract-ai/utils": ["packages/utils/src"],
      "@contract-ai/hooks": ["packages/hooks/src"],
      "@contract-ai/api-client": ["packages/api-client/src"]
    }
  },
  "exclude": ["**/node_modules", "**/.next", "**/dist", "**/.turbo"],
  "include": ["packages/*/src/**/*", "apps/*/src/**/*"]
}
