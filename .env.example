# Database
DATABASE_URL=postgresql://user:password@localhost:5432/contract_ai

# Redis
REDIS_URL=redis://localhost:6379

# Node Environment
NODE_ENV=development

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend API
API_PORT=3001
API_LOG_LEVEL=debug

# AI Service
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_API_KEY=your_google_api_key

# OCR Service
OCR_SERVICE_URL=http://localhost:8001

# Notification Service
NOTIFICATION_SERVICE_URL=http://localhost:8002

# S3/Storage
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=contract-ai-uploads

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE_IN=7d

# Authentication
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH_MICROSOFT_CLIENT_ID=your_microsoft_client_id
OAUTH_MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=contract-ai
KEYCLOAK_CLIENT_ID=contract-ai-client
KEYCLOAK_CLIENT_SECRET=your_keycloak_secret

# Kafka
KAFKA_BROKERS=localhost:9092

# Logging & Monitoring
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn
