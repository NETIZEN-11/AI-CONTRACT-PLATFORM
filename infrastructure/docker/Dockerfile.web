# Build stage
FROM node:22-alpine AS builder

# pnpm 11 requires Node 22.13+. Pin to match the project's packageManager.
ENV PNPM_VERSION=11.6.0
ENV CI=true

WORKDIR /app

# Use corepack so the pnpm version is determined by the lockfile/packageManager.
RUN corepack enable && corepack prepare pnpm@${PNPM_VERSION} --activate

# Install dependencies
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Copy source code
COPY . .

# Build web app
RUN pnpm run build --filter=web

# Production stage
FROM node:22-alpine

ENV PNPM_VERSION=11.6.0
ENV NODE_ENV=production
ENV CI=true

WORKDIR /app

# Use corepack for the runtime stage too
RUN corepack enable && corepack prepare pnpm@${PNPM_VERSION} --activate

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install production dependencies only
RUN pnpm install --prod --frozen-lockfile

# Copy built application and public files
COPY --from=builder /app/apps/web/.next ./apps/web/.next
COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder /app/apps/web/package.json ./apps/web/package.json

WORKDIR /app/apps/web

# Expose port
EXPOSE 3000

# Start application
CMD ["pnpm", "start"]
